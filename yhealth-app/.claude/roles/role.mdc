PART 3
Option B — Client Credentials (App Playlists)
This flow does not require any user login. yHealth fetches curated playlists directly from Spotify's catalogue to offer pre-built music experiences (focus, workout, relaxation) aligned to health goals.
Step 8 — Get a Server-Side App Token
// lib/spotify/appToken.ts
let cachedToken: { token: string; expiresAt: number } | null = null;
 
export async function getSpotifyAppToken(): Promise<string> {
  if (cachedToken && Date.now() < cachedToken.expiresAt) {
    return cachedToken.token;
  }
  const credentials = Buffer.from(
    `${process.env.SPOTIFY_CLIENT_ID}:${process.env.SPOTIFY_CLIENT_SECRET}`
  ).toString('base64');
 
  const res = await fetch('https://accounts.spotify.com/api/token', {
    method: 'POST',
    headers: {
      Authorization: `Basic ${credentials}`,
      'Content-Type': 'application/x-www-form-urlencoded',
    },
    body: 'grant_type=client_credentials',
  });
  const data = await res.json();
  cachedToken = {
    token: data.access_token,
    expiresAt: Date.now() + (data.expires_in - 60) * 1000,
  };
  return cachedToken.token;
}

Step 9 — Fetch Health Playlists by Category
// lib/spotify/healthPlaylists.ts
import { getSpotifyAppToken } from './appToken';
 
// Map yHealth activities to Spotify search queries
const HEALTH_PLAYLIST_MAP = {
  workout:     'Best Workout Hits 2024',
  meditation:  'Deep Meditation Calm',
  sleep:       'Sleep Sounds Nature White Noise',
  focus:       'Deep Focus Study Concentration',
  relaxation:  'Chill Relaxing Lofi',
  running:     'Running Motivation Beats',
};
 
export async function getHealthPlaylist(activity: keyof typeof HEALTH_PLAYLIST_MAP) {
  const token = await getSpotifyAppToken();
  const query = encodeURIComponent(HEALTH_PLAYLIST_MAP[activity]);
  const res = await fetch(
    `https://api.spotify.com/v1/search?q=${query}&type=playlist&limit=5`,
    { headers: { Authorization: `Bearer ${token}` } }
  );
  const data = await res.json();
  return data.playlists?.items ?? [];
}
 
// Fetch tracks from a specific playlist
export async function getPlaylistTracks(playlistId: string) {
  const token = await getSpotifyAppToken();
  const res = await fetch(
    `https://api.spotify.com/v1/playlists/${playlistId}/tracks?limit=50`,
    { headers: { Authorization: `Bearer ${token}` } }
  );
  return res.json();
}

Step 10 — API Route to Serve Playlists to Frontend
// app/api/music/playlists/route.ts
import { getHealthPlaylist } from '@/lib/spotify/healthPlaylists';
import { NextRequest, NextResponse } from 'next/server';
 
export async function GET(req: NextRequest) {
  const activity = req.nextUrl.searchParams.get('activity') ?? 'workout';
  try {
    const playlists = await getHealthPlaylist(activity as any);
    return NextResponse.json({ playlists });
  } catch (err) {
    return NextResponse.json({ error: 'Failed to fetch playlists' }, { status: 500 });
  }
}




PART 4
Web Playback SDK (In-App Player)
To play music inside yHealth (not just launching the Spotify app), use the Spotify Web Playback SDK. Requires Spotify Premium on the user's account.
Step 11 — Load the SDK Script
// components/SpotifyPlayer.tsx
'use client';
import { useEffect, useState } from 'react';
import { useSession } from 'next-auth/react';
 
declare global {
  interface Window { onSpotifyWebPlaybackSDKReady: () => void; Spotify: any; }
}
 
export function useSpotifyPlayer() {
  const { data: session } = useSession();
  const [player, setPlayer] = useState<any>(null);
  const [deviceId, setDeviceId] = useState<string>('');
  const [isPaused, setIsPaused] = useState(true);
  const [currentTrack, setCurrentTrack] = useState<any>(null);
 
  useEffect(() => {
    if (!session?.accessToken) return;
    const script = document.createElement('script');
    script.src = 'https://sdk.scdn.co/spotify-player.js';
    script.async = true;
    document.body.appendChild(script);
 
    window.onSpotifyWebPlaybackSDKReady = () => {
      const p = new window.Spotify.Player({
        name: 'yHealth Player',
        getOAuthToken: (cb: (t: string) => void) => cb(session.accessToken!),
        volume: 0.7,
      });
      p.addListener('ready', ({ device_id }: { device_id: string }) => {
        setDeviceId(device_id);
      });
      p.addListener('player_state_changed', (state: any) => {
        if (!state) return;
        setCurrentTrack(state.track_window.current_track);
        setIsPaused(state.paused);
      });
      p.connect();
      setPlayer(p);
    };
  }, [session?.accessToken]);
 
  const playTrack = async (uri: string) => {
    await fetch(`https://api.spotify.com/v1/me/player/play?device_id=${deviceId}`, {
      method: 'PUT',
      headers: { Authorization: `Bearer ${session?.accessToken}` },
      body: JSON.stringify({ uris: [uri] }),
    });
  };
 
  return { player, isPaused, currentTrack, playTrack,
    togglePlay: () => player?.togglePlay() };
}




PART 5
yHealth AI Music Matching
The most powerful feature: using the user's health data (mood, activity type, heart rate zone from Whoop) to automatically recommend the right music from their Spotify library or curated playlists.
Step 12 — Health-to-Music Mapping Service
// lib/spotify/aiMusicMatch.ts
import { SpotifyClient } from './client';
 
interface HealthContext {
  activity: 'workout' | 'meditation' | 'sleep' | 'focus' | 'recovery';
  heartRateZone?: 1 | 2 | 3 | 4 | 5;  // from Whoop
  mood?: 'stressed' | 'calm' | 'energised' | 'tired';
}
 
// Map health state to Spotify audio features
function healthToAudioFeatures(ctx: HealthContext) {
  const presets = {
    workout:    { min_energy: 0.7, min_tempo: 120, target_valence: 0.8 },
    meditation: { max_energy: 0.3, max_tempo: 80,  target_valence: 0.5 },
    sleep:      { max_energy: 0.2, max_tempo: 70,  target_valence: 0.4 },
    focus:      { min_energy: 0.4, max_energy: 0.7, target_instrumentalness: 0.8 },
    recovery:   { max_energy: 0.4, target_valence: 0.6, target_tempo: 90 },
  };
  return presets[ctx.activity];
}
 
// Get AI-matched recommendations
export async function getHealthMatchedTracks(
  accessToken: string,
  ctx: HealthContext,
  seedTrackIds: string[]
) {
  const features = healthToAudioFeatures(ctx);
  const seeds = seedTrackIds.slice(0, 5).join(',');
  const params = new URLSearchParams({
    seed_tracks: seeds,
    limit: '20',
    ...Object.fromEntries(Object.entries(features).map(([k,v]) => [k, String(v)])),
  });
  const res = await fetch(
    `https://api.spotify.com/v1/recommendations?${params}`,
    { headers: { Authorization: `Bearer ${accessToken}` } }
  );
  return res.json();
}




PART 6
Important Limitations & Legal Notes
⚠️  You CANNOT Download or Store Spotify Audio
Spotify's Terms of Service strictly prohibit downloading, storing, or caching any audio content. yHealth must always stream tracks in real-time via the SDK or Spotify app. Violating this will result in your developer account being suspended.

Free Tier Limitations
•Free Spotify users: 30-second previews only (not full tracks)
•Full track streaming inside yHealth requires the user to have Spotify Premium
•You can use the preview_url field from the Tracks API to play 30s clips with a standard <audio> tag — no SDK needed
•Playlist browsing and metadata is available to all users regardless of tier

30-Second Preview Player (Free Users)
// components/PreviewPlayer.tsx — works for ALL users, no Premium needed
export function PreviewPlayer({ previewUrl, trackName }: {
  previewUrl: string | null;
  trackName: string;
}) {
  if (!previewUrl) return <p>No preview available</p>;
  return (
    <div>
      <p>{trackName} (30s preview)</p>
      <audio controls src={previewUrl} />
    </div>
  );
}

