<%# Password Reset Template %>
<%- include('./layouts/base', {
  title: 'Reset Your Password - Balencia',
  preheader: `${firstName}, here is your password reset link.`,
  eyebrow: 'Password reset',
  greeting: `Reset your password, ${firstName}.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      We received a request to reset the password for your <strong>Balencia</strong> account.
    </p>

    <p style="margin:0 0 24px; font-size:16px; line-height:26px;">
      Use the button below to create a new password. For security reasons, this link expires in <strong>1 hour</strong>.
    </p>

    ${include('./partials/alert-box', {
      type: 'warning',
      message: 'Never share your password or this reset link. Balencia will never ask for your password by email.'
    })}
  `,
  ctaButton: {
    text: 'Reset My Password',
    url: resetUrl,
    color: 'linear-gradient(135deg,#f59e0b 0%,#d97706 100%)'
  },
  secondaryContent: `
    <p style="margin:0 0 12px; font-size:14px; color:#111827; font-weight:800;">Did not request this?</p>
    <p style="margin:0; font-size:13px; color:#78716c; line-height:21px;">
      You can ignore this email. Your password will remain unchanged.
    </p>
  `,
  footerText: 'If you have concerns about account security, contact support@balencia.app immediately.',
  showSocial: false,
  showUnsubscribe: false
}) %>
