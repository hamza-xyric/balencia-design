  "reuse_decisions": {
    "$comment": "Phase 0 reuse-vs-rebuild decisions per figma-generate-library skill section 5.",
    "iPhone device frame": {
      "decision": "reuse",
      "source": "iOS and iPadOS 26 UI kit (community)",
      "rationale": "Pixel-perfect Apple-official iPhone chrome with dynamic island + home indicator. Rebuilding would duplicate Apple's geometry imperfectly."
    },
    "SF Symbols": {
      "decision": "skip",
      "source": "iOS 26 UI kit ships SF Symbols",
      "rationale": "Balencia uses Lucide icons in code, not SF Symbols. Build our own Icon component referencing Lucide; do not import SF Symbols."
    },
    "Material/Simple DS components": {
      "decision": "rebuild",
      "rationale": "Balencia has its own visual language — warm ink + burnt orange — not Material. The component API does not match. Build from scratch in Balencia DS."
    }
  }
