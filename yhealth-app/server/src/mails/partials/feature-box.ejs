<%# Feature/Benefit Box Component %>
<table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:16px 0;">
  <tr>
    <td style="padding:18px; background:#fff7ed; border:1px solid #fed7aa; border-radius:14px;">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
        <tr>
          <td width="48" valign="top" style="padding-right:14px;">
            <div style="width:48px; height:48px; background:linear-gradient(135deg,#f97316 0%,#ea580c 100%); border-radius:14px; text-align:center; line-height:48px; font-size:22px; color:#ffffff;">
              <%= icon %>
            </div>
          </td>
          <td valign="top">
            <p style="margin:0 0 5px; font-weight:800; color:#111827; font-size:15px; line-height:20px;"><%= title %></p>
            <p style="margin:0; color:#57534e; font-size:14px; line-height:21px;"><%= description %></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
