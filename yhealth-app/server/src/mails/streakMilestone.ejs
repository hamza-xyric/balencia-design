<%# Streak Milestone Template %>
<%
  const feature = (icon, title, description) => include('./partials/feature-box', { icon, title, description });
  const daysAway = typeof nextMilestone !== 'undefined' && nextMilestone ? nextMilestone - streakDays : null;
%>
<%- include('./layouts/base', {
  title: 'Streak Milestone - Balencia',
  preheader: `${firstName}, your ${streakDays} day streak is live.`,
  eyebrow: 'Consistency milestone',
  greeting: `${streakDays} days in a row, ${firstName}.`,
  content: `
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:0 0 26px;">
      <tr>
        <td style="text-align:center; background:linear-gradient(135deg,#fff7ed 0%,#ffedd5 100%); border-radius:18px; padding:34px 24px; border:1px solid #fed7aa;">
          <p style="margin:0 0 8px; font-size:72px; font-weight:800; color:#ea580c; line-height:1;">${escapeFn(streakDays)}</p>
          <p style="margin:0; font-size:18px; color:#9a3412; font-weight:800;">Day streak</p>
        </td>
      </tr>
    </table>

    <p style="margin:0 0 24px; font-size:16px; line-height:26px; text-align:center;">
      Consistency is the strongest signal you can give your coach. This streak gives Balencia better context and gives you more momentum.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:24px 0;">
      <tr>
        <td style="padding:24px; background:linear-gradient(135deg,#f97316 0%,#ea580c 100%); border-radius:16px; text-align:center;">
          <p style="margin:0; font-size:16px; color:#ffffff; font-style:italic; line-height:24px;">
            "${escapeFn(typeof motivationalQuote !== 'undefined' ? motivationalQuote : 'The secret of your success is found in your daily routine.')}"
          </p>
          ${typeof quoteAuthor !== 'undefined' && quoteAuthor ? `<p style="margin:12px 0 0; font-size:14px; color:#ffedd5;">- ${escapeFn(quoteAuthor)}</p>` : ''}
        </td>
      </tr>
    </table>

    ${streakDays >= 7 ? `
      <h2 style="margin:30px 0 16px; font-size:18px; color:#111827;">What your streak unlocks</h2>
      ${feature('01', 'Better pattern recognition', 'Your coach can identify more meaningful trends from repeated check-ins.')}
      ${feature('02', 'Sharper insights', 'More data creates more accurate and actionable recommendations.')}
      ${feature('03', 'Stronger habit design', 'You are building routines that can survive busy days.')}
    ` : ''}

    ${daysAway !== null ? include('./partials/alert-box', {
      type: 'success',
      message: `Next milestone: <strong>${escapeFn(nextMilestone)}</strong> days. You are ${escapeFn(daysAway)} day${daysAway === 1 ? '' : 's'} away.`
    }) : ''}
  `,
  ctaButton: {
    text: 'Keep the Streak Going',
    url: dashboardUrl
  },
  footerText: 'Protect the routine, then let the results compound.'
}) %>
