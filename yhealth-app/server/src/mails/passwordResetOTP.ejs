<%# Password Reset OTP Template %>
<%- include('./layouts/base', {
  title: 'Your Password Reset Code - Balencia',
  preheader: `${firstName}, use this password reset code for Balencia.`,
  eyebrow: 'Password reset',
  greeting: `Use this code to reset your password, ${firstName}.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      We received a request to reset your Balencia password. Enter the code below to continue.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:30px 0;">
      <tr>
        <td style="text-align:center; background:#fff7ed; border-radius:18px; padding:34px 24px; border:2px dashed #f97316;">
          <p style="margin:0 0 10px; font-size:12px; color:#c2410c; text-transform:uppercase; letter-spacing:2px; font-weight:800;">Reset code</p>
          <p style="margin:0; font-size:48px; line-height:54px; font-weight:800; color:#9a3412; letter-spacing:10px; font-family:'Courier New',monospace;">${escapeFn(otpCode)}</p>
        </td>
      </tr>
    </table>

    ${include('./partials/alert-box', {
      type: 'error',
      message: `This code expires in <strong>${escapeFn(expiresIn)}</strong>. Never share it with anyone.`
    })}

    <p style="margin:24px 0 0; font-size:14px; line-height:22px; color:#6b7280;">
      If you did not request this code, ignore this email. Your password will remain unchanged.
    </p>
  `,
  footerText: 'For security concerns, contact support@balencia.app immediately.',
  showSocial: false,
  showUnsubscribe: false
}) %>
