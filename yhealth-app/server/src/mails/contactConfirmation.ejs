<%# Contact Form Submission Confirmation Email Template %>
<%- include('./layouts/base', {
  title: 'We Received Your Message - Balencia',
  preheader: `Thank you for contacting Balencia, ${name}. We received your message.`,
  eyebrow: 'Support request received',
  greeting: `We received your message, ${name}.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      Thanks for reaching out. Your request has been logged and our team will review it with care.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:28px 0; background:#fff7ed; border:1px solid #fed7aa; border-radius:16px;">
      <tr>
        <td style="padding:24px;">
          <p style="margin:0 0 14px; font-size:12px; color:#c2410c; text-transform:uppercase; letter-spacing:1.5px; font-weight:800;">Your submission</p>
          <p style="margin:0 0 6px; font-size:13px; color:#78716c; font-weight:700;">Subject</p>
          <p style="margin:0 0 18px; font-size:16px; color:#111827; font-weight:800;">${escapeFn(subject)}</p>
          <p style="margin:0 0 6px; font-size:13px; color:#78716c; font-weight:700;">Message</p>
          <p style="margin:0; font-size:15px; line-height:24px; color:#374151; white-space:pre-wrap;">${escapeFn(message)}</p>
        </td>
      </tr>
    </table>

    ${include('./partials/feature-box', {
      icon: '24h',
      title: 'Reviewed by a real support specialist',
      description: 'Most inquiries receive a thoughtful reply within one business day.'
    })}
    ${include('./partials/feature-box', {
      icon: '01',
      title: 'Next update by email',
      description: 'We will respond directly to the address used for this request.'
    })}
  `,
  ctaButton: {
    text: 'Open Dashboard',
    url: typeof dashboardUrl !== 'undefined' ? dashboardUrl : '#'
  },
  secondaryContent: `
    <p style="margin:0; font-size:14px; line-height:22px;">
      Need quick answers while you wait? Visit the <a href="${escapeFn(typeof helpUrl !== 'undefined' ? helpUrl : '#')}" style="color:#ea580c; font-weight:800;">help center</a>.
    </p>
  `,
  footerText: `This confirmation was sent to ${email}.`
}) %>
