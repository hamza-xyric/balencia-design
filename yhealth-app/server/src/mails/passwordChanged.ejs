<%# Password Changed Confirmation Template %>
<%
  const detailRows = [
    ['Changed on', changedAt],
    typeof ipAddress !== 'undefined' && ipAddress ? ['IP address', ipAddress] : null,
    typeof device !== 'undefined' && device ? ['Device', device] : null
  ].filter(Boolean).map(([label, value]) => `
    <tr>
      <td style="padding:10px 0; border-top:1px solid #ffedd5;">
        <span style="color:#78716c; font-size:14px;">${escapeFn(label)}:</span>
        <span style="color:#111827; font-size:14px; font-weight:800; float:right;">${escapeFn(value)}</span>
      </td>
    </tr>
  `).join('');
%>
<%- include('./layouts/base', {
  title: 'Password Changed - Balencia',
  preheader: `${firstName}, your Balencia password has been changed.`,
  eyebrow: 'Security confirmation',
  greeting: `Your password was updated, ${firstName}.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      Your password has been successfully changed. You can now sign in with your new credentials.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:24px 0; background:#fff7ed; border-radius:16px; border:1px solid #fed7aa;">
      <tr>
        <td style="padding:22px;">
          <p style="margin:0 0 8px; font-size:12px; color:#c2410c; text-transform:uppercase; letter-spacing:1.5px; font-weight:800;">Change details</p>
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
            ${detailRows}
          </table>
        </td>
      </tr>
    </table>

    ${include('./partials/alert-box', {
      type: 'error',
      message: `If this was not you, reset your password immediately: <a href="${escapeFn(resetUrl)}" style="color:#dc2626; font-weight:800;">secure your account</a>.`
    })}
  `,
  ctaButton: {
    text: 'Go to Dashboard',
    url: dashboardUrl,
    color: 'linear-gradient(135deg,#10b981 0%,#059669 100%)'
  },
  footerText: 'For security concerns, contact support@balencia.app immediately.',
  showSocial: false,
  showUnsubscribe: false
}) %>
