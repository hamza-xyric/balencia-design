<%# Task Reminder Template %>
<%
  const priorityValue = priority || 'normal';
  const priorityBg = priorityValue === 'urgent' ? '#fee2e2' : priorityValue === 'high' ? '#ffedd5' : priorityValue === 'medium' ? '#fef3c7' : '#ecfdf5';
  const priorityColor = priorityValue === 'urgent' ? '#dc2626' : priorityValue === 'high' ? '#ea580c' : priorityValue === 'medium' ? '#ca8a04' : '#047857';
  const categoryValue = category || 'general';
  const categoryLabel = categoryValue.charAt(0).toUpperCase() + categoryValue.slice(1);
  const hasDescription = taskDescription && taskDescription !== 'No description provided';
%>
<%- include('./layouts/base', {
  title: 'Task Reminder - Balencia',
  preheader: `${firstName}, you have a task coming up: ${taskTitle}.`,
  eyebrow: 'Task reminder',
  greeting: `A task is coming up, ${firstName}.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      Stay close to the plan. This task is scheduled and ready for your next action.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:26px 0; background:linear-gradient(135deg,#fff7ed 0%,#ecfdf5 100%); border-radius:18px; border:1px solid #fed7aa;">
      <tr>
        <td style="padding:26px; text-align:center;">
          <span style="display:inline-block; background:${priorityBg}; color:${priorityColor}; padding:5px 13px; border-radius:999px; font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:.5px;">
            ${escapeFn(priorityValue)} priority
          </span>
          <p style="margin:18px 0 8px; font-size:23px; line-height:30px; font-weight:800; color:#111827;">${escapeFn(taskTitle)}</p>
          ${hasDescription ? `<p style="margin:0 0 18px; font-size:14px; line-height:22px; color:#6b7280;">${escapeFn(taskDescription)}</p>` : ''}
          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background:#ffffff; border-radius:12px; border:1px solid #ffedd5;">
            <tr>
              <td style="padding:16px; text-align:center;">
                <p style="margin:0 0 4px; font-size:12px; color:#9a3412; text-transform:uppercase; letter-spacing:1.3px; font-weight:800;">Scheduled for</p>
                <p style="margin:0; font-size:18px; font-weight:800; color:#ea580c;">${escapeFn(scheduledTime)}</p>
              </td>
            </tr>
          </table>
          <p style="margin:16px 0 0; font-size:12px; color:#57534e;">Category: ${escapeFn(categoryLabel)}</p>
        </td>
      </tr>
    </table>

    <div style="text-align:center; margin:24px 0;">
      <a href="${escapeFn(completeUrl)}" style="display:inline-block; background:linear-gradient(135deg,#10b981 0%,#059669 100%); color:#ffffff; padding:12px 24px; border-radius:999px; text-decoration:none; font-weight:800; font-size:14px;">
        Mark Complete
      </a>
    </div>

    <p style="margin:24px 0 0; font-size:14px; font-style:italic; color:#6b7280; text-align:center;">
      "The key is not to prioritize what's on your schedule, but to schedule your priorities." - Stephen Covey
    </p>
  `,
  ctaButton: {
    text: 'View Task Details',
    url: dashboardUrl
  },
  footerText: 'Keep the momentum visible and simple.'
}) %>
