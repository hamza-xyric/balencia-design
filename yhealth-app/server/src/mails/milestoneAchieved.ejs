<%# Milestone Achieved Template %>
<%
  const statRows = typeof stats !== 'undefined' && stats ? [
    stats.daysActive ? ['Days active', stats.daysActive, '#ea580c'] : null,
    stats.totalCheckIns ? ['Total check-ins', stats.totalCheckIns, '#10b981'] : null,
    stats.goalsCompleted ? ['Goals completed', stats.goalsCompleted, '#f59e0b'] : null
  ].filter(Boolean).map(([label, value, color]) => `
    <tr>
      <td style="padding:9px 0; border-top:1px solid #ffedd5;">
        <span style="color:#111827; font-size:14px;">${escapeFn(label)}</span>
        <span style="color:${color}; font-size:14px; font-weight:800; float:right;">${escapeFn(value)}</span>
      </td>
    </tr>
  `).join('') : '';
%>
<%- include('./layouts/base', {
  title: 'Milestone Achieved - Balencia',
  preheader: `${firstName}, you reached an important milestone.`,
  eyebrow: 'Milestone achieved',
  greeting: `This is worth celebrating, ${firstName}.`,
  content: `
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:0 0 28px;">
      <tr>
        <td style="background:linear-gradient(135deg,#fffbeb 0%,#fff7ed 100%); border-radius:18px; padding:30px; text-align:center; border:2px solid #f59e0b;">
          <p style="margin:0 0 8px; font-size:12px; color:#92400e; text-transform:uppercase; letter-spacing:1.6px; font-weight:800;">${escapeFn(milestoneCategory)}</p>
          <p style="margin:0 0 10px; font-size:26px; line-height:34px; color:#92400e; font-weight:800;">${escapeFn(milestoneTitle)}</p>
          <p style="margin:0; font-size:16px; line-height:24px; color:#b45309;">${escapeFn(milestoneDescription)}</p>
        </td>
      </tr>
    </table>

    <p style="margin:0 0 24px; font-size:16px; line-height:26px;">
      This achievement reflects real consistency. Take a moment to notice the progress, then let your coach help choose the next clean step.
    </p>

    ${statRows ? `
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:24px 0; background:#fff7ed; border-radius:16px; border:1px solid #fed7aa;">
        <tr>
          <td style="padding:22px;">
            <p style="margin:0 0 8px; font-size:12px; color:#c2410c; text-transform:uppercase; letter-spacing:1.5px; font-weight:800;">Your journey so far</p>
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">${statRows}</table>
          </td>
        </tr>
      </table>
    ` : ''}

    ${include('./partials/alert-box', {
      type: 'info',
      message: "Your AI coach has identified new opportunities for growth. Check your dashboard to see what's next."
    })}
  `,
  ctaButton: {
    text: 'See My Progress',
    url: dashboardUrl,
    color: 'linear-gradient(135deg,#f59e0b 0%,#d97706 100%)'
  },
  footerText: 'Every milestone is a signal that your system is working.'
}) %>
