<%# Weekly Digest Summary Template %>
<%
  const safeHighlights = Array.isArray(highlights) ? highlights : [];
  const safeInsights = Array.isArray(insights) ? insights : [];
  const highlightRows = safeHighlights.map((h) => `
    <tr>
      <td style="padding:16px; background:#fff7ed; border:1px solid #fed7aa; border-radius:12px;">
        <p style="margin:0 0 4px; font-size:14px; font-weight:800; color:#111827;">${escapeFn(h.title)}</p>
        <p style="margin:0; font-size:13px; line-height:20px; color:#6b7280;">${escapeFn(h.description)}</p>
      </td>
    </tr>
    <tr><td style="height:10px;"></td></tr>
  `).join('');
  const insightRows = safeInsights.map((insight) => `
    <p style="margin:0 0 8px; padding-left:14px; border-left:3px solid #10b981; font-size:14px; line-height:22px; color:#4b5563;">
      ${escapeFn(insight)}
    </p>
  `).join('');
%>
<%- include('layouts/base', {
  title: subject || 'Your Weekly Summary',
  preheader: coachMessage ? coachMessage.substring(0, 80) : 'Here is your weekly health summary.',
  eyebrow: 'Weekly intelligence',
  greeting: `Your week in review, ${firstName || 'there'}.`,
  content: `
    <p style="margin:0 0 8px; font-size:13px; color:#9a3412; text-transform:uppercase; letter-spacing:1.6px; font-weight:800;">
      ${escapeFn(weekStart || '')} to ${escapeFn(weekEnd || '')}
    </p>
    <p style="margin:0 0 24px; font-size:16px; line-height:26px;">
      Here is the concise view of what moved, what mattered, and where your coach recommends focus next.
    </p>

    ${highlightRows ? `
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:0 0 24px;">
        ${highlightRows}
      </table>
    ` : ''}

    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:0 0 24px;">
      <tr>
        <td style="padding:22px; background:linear-gradient(135deg,#fff7ed 0%,#ffedd5 100%); border-radius:16px; border-left:5px solid #f97316;">
          <p style="margin:0 0 6px; font-size:12px; font-weight:800; color:#c2410c; text-transform:uppercase; letter-spacing:1.5px;">Coach's note</p>
          <p style="margin:0; font-size:15px; line-height:24px; color:#1f2937;">${escapeFn(coachMessage || 'Great work this week. Keep the next step simple and repeatable.')}</p>
        </td>
      </tr>
    </table>

    ${insightRows ? `
      <h2 style="margin:28px 0 14px; font-size:18px; color:#111827;">Key insights</h2>
      ${insightRows}
    ` : ''}

    ${nextWeekFocus ? `
      <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:24px 0 0;">
        <tr>
          <td style="padding:18px; background:#ecfdf5; border-radius:14px; border:1px solid #a7f3d0;">
            <p style="margin:0 0 4px; font-size:12px; font-weight:800; color:#047857; text-transform:uppercase; letter-spacing:1.4px;">Next week focus</p>
            <p style="margin:0; font-size:15px; line-height:23px; color:#065f46;">${escapeFn(nextWeekFocus)}</p>
          </td>
        </tr>
      </table>
    ` : ''}
  `,
  ctaButton: {
    text: 'View Full Dashboard',
    url: `${appUrl || 'https://balencia.app'}/dashboard`
  },
  footerText: 'Your weekly summary is designed to make the next right action obvious.'
}) %>
