<%# Onboarding Complete Template %>
<%
  const feature = (icon, title, description) => include('./partials/feature-box', { icon, title, description });
  const completedRows = [
    'Created your account',
    'Verified your email',
    'Completed your health assessment',
    typeof connectedDevices !== 'undefined' && connectedDevices > 0 ? `Connected ${connectedDevices} device${connectedDevices > 1 ? 's' : ''}` : '',
    typeof goalsSet !== 'undefined' && goalsSet > 0 ? `Set ${goalsSet} goal${goalsSet > 1 ? 's' : ''}` : ''
  ].filter(Boolean).map((label) => `
    <p style="margin:0 0 10px; color:#111827; font-size:15px; font-weight:700;">${escapeFn(label)}</p>
  `).join('');
%>
<%- include('./layouts/base', {
  title: "You're All Set - Balencia",
  preheader: `${firstName}, your Balencia setup is complete.`,
  eyebrow: 'Setup complete',
  greeting: `Your coach is fully initialized, ${firstName}.`,
  content: `
    <p style="margin:0 0 24px; font-size:16px; line-height:26px;">
      Your AI Life Coach now has enough context to begin giving sharper, more personal guidance.
    </p>

    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="margin:24px 0; background:linear-gradient(135deg,#ecfdf5 0%,#fff7ed 100%); border-radius:16px; border:1px solid #a7f3d0;">
      <tr>
        <td style="padding:24px;">
          <p style="margin:0 0 12px; font-size:12px; color:#047857; text-transform:uppercase; letter-spacing:1.5px; font-weight:800;">Completed setup</p>
          ${completedRows}
        </td>
      </tr>
    </table>

    <h2 style="margin:30px 0 16px; font-size:18px; color:#111827;">Best places to begin</h2>
    ${feature('01', 'Chat with your coach', 'Ask a question, share a constraint, or set the next practical action.')}
    ${feature('02', 'Enable thoughtful reminders', 'Receive useful nudges without turning your day into a notification stream.')}
    ${feature('03', 'Explore your dashboard', 'Review your health signals and see where patterns are beginning to form.')}

    ${include('./partials/alert-box', {
      type: 'info',
      message: 'A quick morning check-in gives your coach the freshest context for better recommendations.'
    })}
  `,
  ctaButton: {
    text: 'Go to My Dashboard',
    url: dashboardUrl,
    color: 'linear-gradient(135deg,#10b981 0%,#059669 100%)'
  },
  footerText: 'Your journey to better health starts with the next small action.'
}) %>
