<%# AI Coach Insight Template %>
<%- include('layouts/base', {
  title: subject || 'A Message from Your AI Coach',
  preheader: body ? body.substring(0, 80) : 'Your AI coach has a new insight for you.',
  eyebrow: 'Coach insight',
  greeting: `Hi ${firstName || 'there'}, your coach has a timely note.`,
  content: `
    <p style="margin:0 0 22px; font-size:16px; line-height:26px;">
      A new pattern surfaced in your coaching context. Here is the highest-signal takeaway for today:
    </p>

    <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:26px 0;">
      <tr>
        <td style="padding:24px; background:linear-gradient(135deg,#fff7ed 0%,#ecfdf5 100%); border-radius:16px; border-left:5px solid #10b981;">
          <p style="margin:0 0 8px; font-size:12px; color:#047857; text-transform:uppercase; letter-spacing:1.5px; font-weight:800;">AI coach note</p>
          <p style="margin:0; font-size:17px; line-height:27px; color:#111827; font-weight:600;">
            ${escapeFn(body || 'Check your chat for the latest insight.')}
          </p>
        </td>
      </tr>
    </table>

    <p style="margin:0; font-size:15px; line-height:24px; color:#6b7280;">
      Open the coach thread when you are ready to turn this into your next action.
    </p>
  `,
  ctaButton: {
    text: cta || 'Open Coach',
    url: `${appUrl || 'https://balencia.app'}/chat`
  },
  footerText: 'Your Balencia coach gets sharper as your context grows.'
}) %>
